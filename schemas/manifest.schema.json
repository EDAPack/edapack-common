{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://edapack.github.io/schemas/manifest.schema.json",
  "title": "edapack release manifest",
  "description": "Machine-readable record of what went into a release, shipped as manifest.json.",
  "type": "object",
  "required": ["schema", "package", "release", "inputs_digest", "inputs"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "edapack.manifest/1" },
    "package": { "type": "string" },
    "release": {
      "type": "object",
      "required": ["version", "tag", "built_at", "trigger", "recipe_sha"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string" },
        "tag": { "type": "string" },
        "built_at": { "type": "string", "format": "date-time" },
        "trigger": { "enum": ["schedule", "workflow_dispatch", "push"] },
        "recipe_sha": { "type": "string" }
      }
    },
    "inputs_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/input" }
    },
    "platform": { "$ref": "#/$defs/platform" },
    "platforms": {
      "type": "array",
      "items": { "$ref": "#/$defs/platform" }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "version", "binaries"],
        "additionalProperties": true,
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "binaries": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  },
  "$defs": {
    "input": {
      "type": "object",
      "required": ["name", "role", "repo", "ref", "resolved_sha"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "role": { "enum": ["core", "dependency"] },
        "repo": { "type": "string" },
        "ref": { "type": "string" },
        "resolved_sha": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
        "version": { "type": ["string", "null"] },
        "tracked": { "type": "boolean", "default": true }
      }
    },
    "platform": {
      "type": "object",
      "required": ["os", "arch"],
      "additionalProperties": false,
      "properties": {
        "os": { "type": "string" },
        "arch": { "type": "string" },
        "libc": { "type": "string" },
        "image": { "type": "string" },
        "artifact": { "type": "string" },
        "sha256": { "type": "string" }
      }
    }
  }
}
