{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://edapack.github.io/schemas/skill-manifest.schema.json",
  "title": "edapack skill-manifest",
  "description": "Per-package list of Agent Skills to validate and stage into a release (consumed by stage-skills.py).",
  "type": "object",
  "required": ["skills"],
  "additionalProperties": false,
  "properties": {
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+$" },
          "path": { "type": "string", "description": "Skill dir relative to --source-root." },
          "binaries": {
            "type": "array",
            "items": { "type": "string" },
            "default": [],
            "description": "Executables that must exist in <release>/bin/."
          }
        }
      }
    }
  }
}
